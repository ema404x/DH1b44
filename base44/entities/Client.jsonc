{
  "name": "Client",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nombre o raz\u00f3n social del proveedor"
    },
    "rubro": {
      "type": "string",
      "description": "Rubro o actividad principal",
      "enum": [
        "construccion",
        "electricidad",
        "plomeria",
        "pintura",
        "carpinteria",
        "herreria",
        "climatizacion",
        "albanileria",
        "impermeabilizacion",
        "materiales",
        "equipos",
        "limpieza",
        "seguridad",
        "transporte",
        "tecnologia",
        "otro"
      ]
    },
    "comuna": {
      "type": "string",
      "description": "Comuna a la que pertenece",
      "enum": [
        "8A",
        "8B",
        "10A",
        "Sin asignar"
      ]
    },
    "cuit": {
      "type": "string"
    },
    "contact_name": {
      "type": "string",
      "description": "Persona de contacto"
    },
    "email": {
      "type": "string"
    },
    "phone": {
      "type": "string",
      "description": "Tel\u00e9fono de contacto"
    },
    "address": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "activo",
        "inactivo",
        "suspendido"
      ],
      "default": "activo"
    },
    "valoracion": {
      "type": "number",
      "description": "Valoraci\u00f3n del proveedor del 1 al 5",
      "minimum": 1,
      "maximum": 5
    },
    "notas_valoracion": {
      "type": "string",
      "description": "Comentarios sobre el desempe\u00f1o del proveedor"
    },
    "sector_id": {
      "type": "string",
      "default": "escuela",
      "description": "Sector/unidad de negocio. A\u00edsla datos entre sectores. Valor libre definido en la entidad Sector."
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "name"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "$and": [
        {
          "data.sector_id": "{{user.data.sector_id}}"
        },
        {
          "$or": [
            {
              "user_condition": {
                "role": "admin"
              }
            },
            {
              "user_condition": {
                "role": "gerente"
              }
            }
          ]
        }
      ]
    },
    "update": {
      "$and": [
        {
          "data.sector_id": "{{user.data.sector_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$and": [
        {
          "data.sector_id": "{{user.data.sector_id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}