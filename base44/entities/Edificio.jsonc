{
  "name": "Edificio",
  "type": "object",
  "properties": {
    "nombre": {
      "type": "string",
      "description": "Nombre del edificio / establecimiento"
    },
    "direccion": {
      "type": "string"
    },
    "comuna": {
      "type": "string",
      "enum": [
        "8A",
        "8B",
        "10A",
        "Otra"
      ]
    },
    "jefe_sitio": {
      "type": "string",
      "description": "Nombre del jefe de sitio responsable"
    },
    "location_id": {
      "type": "string",
      "description": "ID de la LocationData de origen"
    },
    "activo": {
      "type": "boolean",
      "default": true
    },
    "sector_id": {
      "type": "string",
      "enum": [
        "escuela",
        "bapro"
      ],
      "default": "escuela",
      "description": "Sector/unidad de negocio. A\u00edsla datos entre sectores."
    }
  },
  "required": [
    "nombre"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "$and": [
            {
              "data.sector_id": "{{user.data.sector_id}}"
            },
            {
              "data.jefe_sitio": "{{user.full_name}}"
            }
          ]
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}